# Copy this file to .env and edit values for a COPY of BUY.GDB.
# Never point these scripts at the original production database.

LEGACY_DB_PATH=C:\path\to\copy\BUY.GDB
LEGACY_DB_HOST=
LEGACY_DB_USER=SYSDBA
LEGACY_DB_PASSWORD=masterkey
LEGACY_DB_CHARSET=WIN1251
LEGACY_DB_ROLE=

# Optional portable native client. Prefer Firebird 2.5.x Win64 first.
# Example:
# LEGACY_FIREBIRD_CLIENT=C:\Users\Egor\Buy\buy-modern\tools\firebird\fbclient.dll
LEGACY_FIREBIRD_CLIENT=

# Safety switch. The scripts refuse to run unless this is true.
LEGACY_CONFIRM_COPY=false

# Output directory, relative to buy-modern/ by default.
LEGACY_OUTPUT_DIR=migration/legacy_schema

# Used by export_sample_rows.py.
LEGACY_SAMPLE_LIMIT=50
